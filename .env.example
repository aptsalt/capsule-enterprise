# RELAY — copy to .env.local and fill in on hackathon day.

# Cerebras (primary distiller — wafer-scale, sub-second). Get key at cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Backboard.io (portable handoff memory — $100 hackathon credit). Get key at backboard.io
BACKBOARD_API_KEY=

# Local fallbacks (work with no keys — uses your Ollama)
OLLAMA_URL=http://localhost:11434
RELAY_OLLAMA_MODEL=qwen2.5-coder:14b
