# CAPSULE — copy to .env.local and fill in. All keys are OPTIONAL; the app runs with none.

# Cerebras (optional cloud distill boost — wafer-scale). Get key at cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Backboard.io (portable handoff memory; without it, capsules fall back to a local JSON store).
BACKBOARD_API_KEY=

# Local fallbacks (work with no keys — uses your Ollama)
OLLAMA_URL=http://localhost:11434
RELAY_OLLAMA_MODEL=qwen2.5-coder:14b
